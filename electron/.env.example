# ---------------------------------------------------------------------------
# Hotaru — code signing environment variables
#
# Copy this file to .env and fill in your credentials.
# .env is git-ignored and never committed.
#
# electron-builder reads these automatically — no changes to package.json needed.
# Leave a variable unset (or blank) to skip signing for that platform.
# ---------------------------------------------------------------------------


# ===========================================================================
# WINDOWS — Standard OV certificate (.pfx file)
#
# 1. Buy an OV (or EV) certificate from DigiCert, Sectigo, SSL.com, etc.
#    OV: ~$200-400/yr — SmartScreen reputation builds over time (~weeks)
#    EV: ~$400-700/yr — SmartScreen "Unknown Publisher" warning gone immediately
#       (EV requires a hardware token; see notes below)
#
# 2. Export your certificate as a .pfx (PKCS#12) file with a password.
#
# 3. For CI/CD: base64-encode the .pfx and set WIN_CSC_LINK to the encoded string.
#    $ base64 -i MyCert.pfx | tr -d '\n'
#    Locally: set WIN_CSC_LINK to the file path (e.g. /path/to/MyCert.pfx)
# ===========================================================================

# Path to .pfx file, OR base64-encoded .pfx content
WIN_CSC_LINK=

# Password used when exporting the .pfx
WIN_CSC_KEY_PASSWORD=

# EV certificates (hardware token / HSM):
#   electron-builder uses signtool.exe automatically on Windows.
#   Set WIN_CSC_LINK to the certificate's Subject Name instead of a file path,
#   e.g.  WIN_CSC_LINK="My Company Name"
#   The token must be plugged in and unlocked before running dist:win.


# ===========================================================================
# MACOS — Developer ID signing + notarization
#
# Requirements:
#   • Apple Developer Program membership ($99/yr) — developer.apple.com
#   • "Developer ID Application" certificate installed in your Mac Keychain
#     (Xcode → Settings → Accounts → Manage Certificates, or via developer.apple.com)
#
# Signing identity format:  "Developer ID Application: Your Name (TEAMID)"
#   Find yours:  security find-identity -v -p codesigning
# ===========================================================================

# Your 10-character Apple Team ID (visible at developer.apple.com → Membership)
APPLE_TEAM_ID=

# --- Notarization: Apple ID method (simpler for individuals) ----------------
#
# 1. Sign in at appleid.apple.com → App-Specific Passwords → Generate
# 2. Use your Apple ID email and the generated password below.

APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=

# --- Notarization: API Key method (recommended for CI/CD) -------------------
#
# Preferred over Apple ID + password because it doesn't require 2FA and
# the key can be scoped to only what notarization needs.
#
# 1. App Store Connect → Users and Access → Integrations → App Store Connect API
# 2. Create a key with "Developer" role — download the .p8 file (save it safely,
#    Apple only lets you download it once).
# 3. Note the Key ID (10 chars) and Issuer ID (UUID).
#
# electron-builder uses API key if APPLE_API_KEY_ID is set,
# falling back to Apple ID if it's not.

APPLE_API_KEY_ID=
APPLE_API_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
APPLE_API_ISSUER=

# macOS signing identity (auto-detected from Keychain if CSC_NAME is set)
# Example:  CSC_NAME=Developer ID Application: Acme Inc (ABC123DEFG)
CSC_NAME=
