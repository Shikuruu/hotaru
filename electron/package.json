{
  "name": "hotaru",
  "version": "0.1.0",
  "description": "Hotaru — an AI companion that lives on your desktop",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icons": "node scripts/generate-icons.js",
    "dist:win": "npm run icons && npm run build && electron-builder --win",
    "dist:mac": "npm run icons && npm run build && electron-builder --mac",
    "dist": "npm run icons && npm run build && electron-builder"
  },
  "dependencies": {
    "keytar": "^7.9.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@rollup/rollup-win32-x64-msvc": "^4.60.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  },
  "build": {
    "appId": "com.hotaru.desktop",
    "productName": "Hotaru",

    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },

    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],

    "asar": true,
    "asarUnpack": [
      "node_modules/keytar/**",
      "node_modules/uiohook-napi/**"
    ],

    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "Hotaru"
    },

    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity",
      "darkModeSupport": true
    },

    "dmg": {
      "title": "Install Hotaru",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 140, "y": 180, "type": "file" },
        { "x": 400, "y": 180, "type": "link", "path": "/Applications" }
      ]
    },

    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png",
      "category": "Utility"
    }
  }
}
